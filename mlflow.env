# mlflow/mlflow.env
# Environment variables for the MLflow tracking server container.

# Backend store — use the Airflow/Football Postgres instance (separate DB)
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://mlflow:mlflow@airflow-db/mlflow

# Artefact store — S3 bucket already provisioned by Terraform (v7)
MLFLOW_DEFAULT_ARTIFACT_ROOT=s3://football-data-lake/mlflow/artifacts

# AWS credentials (injected by docker-compose from the host .env)
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION}

# Server tuning
MLFLOW_WORKERS=2
GUNICORN_CMD_ARGS="--timeout 120"
