{
  "expectation_suite_name": "matches_suite",
  "expectations": [
    {
      "expectation_type": "expect_table_columns_to_match_ordered_list",
      "kwargs": {
        "column_list": [
          "match_id", "season", "home_team", "away_team",
          "home_goals", "away_goals", "match_date"
        ]
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "match_id" }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "season" }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "home_team" }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "away_team" }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "home_goals" }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "away_goals" }
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": { "column": "match_id" }
    },
    {
      "expectation_type": "expect_column_values_to_be_of_type",
      "kwargs": { "column": "home_goals", "type_": "int" }
    },
    {
      "expectation_type": "expect_column_values_to_be_of_type",
      "kwargs": { "column": "away_goals", "type_": "int" }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": { "column": "home_goals", "min_value": 0, "max_value": 20 }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": { "column": "away_goals", "min_value": 0, "max_value": 20 }
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {
        "column": "season",
        "regex": "^\\d{4}-\\d{2}$"
      }
    },
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": { "min_value": 1, "max_value": 500 }
    },
    {
      "expectation_type": "expect_column_pair_values_to_not_be_equal",
      "kwargs": { "column_A": "home_team", "column_B": "away_team" }
    }
  ],
  "meta": {
    "great_expectations_version": "0.18.x"
  }
}
